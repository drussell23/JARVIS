# Core dumps (but allow backend/core/ and backend/voice_unlock/core/ directories)
# Note: Negation must come AFTER to override
core
core.*
# Exception: Allow backend/core directory and its contents
!backend/core/
!backend/core/**
!backend/core/**/*
# Exception: Allow backend/voice_unlock/core directory (physics-aware authentication)
!backend/voice_unlock/core/
!backend/voice_unlock/core/**
!backend/voice_unlock/core/**/*
# Exception: Allow docs/core directory (documentation)
!docs/core/
!docs/core/**
!docs/core/**/*
# Exception: Allow tests/core directory (integration/unit tests for backend/core)
!tests/core/
!tests/core/**
!tests/core/**/*
# Exception: Allow tests/unit/core directory (unit tests for backend/core)
!tests/unit/core/
!tests/unit/core/**
!tests/unit/core/**/*
# Exception: Allow backend/context_intelligence/core directory
!backend/context_intelligence/core/
!backend/context_intelligence/core/**
!backend/context_intelligence/core/**/*
# Exception: Allow tests/unit/backend/core directory (unit tests for backend/core modules)
!tests/unit/backend/core/
!tests/unit/backend/core/**
!tests/unit/backend/core/**/*
# Re-exclude pyc/pycache in test directories (negations above would un-ignore them)
tests/core/**/__pycache__/
tests/core/**/*.pyc
tests/unit/core/**/__pycache__/
tests/unit/core/**/*.pyc
tests/unit/backend/core/**/__pycache__/
tests/unit/backend/core/**/*.pyc
# But still ignore build artifacts and cache in backend/core/
backend/core/__pycache__/
backend/core/**/__pycache__/
backend/core/build/
backend/core/**/*.so
backend/core/**/*.dylib
backend/core/**/*.pyc
# Allow model files in backend/core/models/ (small enough to track)
# Uncomment below to ignore large model files if needed:
# backend/core/models/*.pth
# backend/core/models/*.bin
# backend/core/models/*.mlpackage/
# Ignore pycache in voice_unlock/core
backend/voice_unlock/core/__pycache__/

# Benchmark results
benchmark_results/
*.bench
