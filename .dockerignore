# Virtual environments
venv/
.venv/
env/
.env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Data and models (mounted as volumes)
data/
models/
*.gguf
*.bin
*.safetensors

# Logs
logs/
*.log

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Node modules (frontend)
node_modules/
frontend/node_modules/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Docker files (avoid recursion)
docker/Dockerfile.*

# Documentation
docs/
*.md
LICENSE

# Tests
tests/
test_*/
*_test.py
test_*.py
pytest.ini
.pytest_cache/

# Config files not needed in container
terraform/
# NOTE (Slice 140): scripts/ is NOT excluded — the soak container ENTRYPOINT is
# scripts/launch_shadow_soak.sh, so scripts/ must stay in the build context.
.claude/
*.tfvars
*.tfstate*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary files
tmp/
temp/
*.tmp

# Credentials (should use secrets)
credentials/
*.json
!package.json
!tsconfig.json

# Large model files
*.pt
*.pth
*.h5
*.hdf5
*.pkl
*.pickle

# Cache directories
.cache/
.huggingface/

# ── Slice 140: secrets + crypto must NEVER be baked into an image layer ──
# They mount at RUNTIME (docker-compose.soak.yml: env_file .env + ./.jarvis volume).
.env
.env.*
\!.env.example
.jarvis/
.claude/worktrees/

# ── Battle-test / soak RUNTIME output — never needed in the image, and HUGE
# (.ouroboros session debug.logs alone were 2.3GB, dwarfing the real context
# and stalling `docker build` on context transfer). Pure runtime artifacts.
.ouroboros/
.ouroboros/**
*.debug.log
**/sessions/**
